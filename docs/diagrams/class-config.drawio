<mxfile host="app.diagrams.net">
  <diagram name="配置与AOP切面类图" id="class-config">
    <mxGraphModel dx="1572" dy="868" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="侗乡医药数字化展示平台 — 配置与AOP切面类图" vertex="1">
          <mxGeometry height="35" width="500" x="430" y="10" as="geometry" />
        </mxCell>
        <mxCell id="aop_header" parent="1" style="swimlane;startSize=25;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;" value="AOP 切面层" vertex="1">
          <mxGeometry height="250" width="660" x="20" y="60" as="geometry" />
        </mxCell>
        <mxCell id="OperationLogAspect" parent="aop_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;OperationLogAspect&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Aspect @Component&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— mqProducer : MqProducer&lt;hr size=&#39;1&#39;&gt;+ around(joinPoint) : Object&lt;br&gt;&lt;small&gt;拦截 @OperationLog 注解&lt;br&gt;记录: 用户/模块/操作/方法/参数/IP/耗时&lt;br&gt;通过MQ异步写入DB&lt;/small&gt;" vertex="1">
          <mxGeometry height="140" width="210" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="RateLimitAspect" parent="aop_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;RateLimitAspect&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Aspect @Component&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— stringRedisTemplate&lt;hr size=&#39;1&#39;&gt;+ around(joinPoint) : Object&lt;br&gt;&lt;small&gt;拦截 @RateLimit 注解&lt;br&gt;基于Redis滑动窗口限流&lt;br&gt;默认: 100次/分钟&lt;/small&gt;" vertex="1">
          <mxGeometry height="140" width="200" x="230" y="35" as="geometry" />
        </mxCell>
        <mxCell id="LoggingAspect" parent="aop_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;LoggingAspect&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Aspect @Component&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ around(joinPoint) : Object&lt;br&gt;&lt;small&gt;记录请求耗时&lt;br&gt;超过阈值告警&lt;br&gt;Controller层自动拦截&lt;/small&gt;" vertex="1">
          <mxGeometry height="120" width="200" x="440" y="35" as="geometry" />
        </mxCell>
        <mxCell id="filter_header" parent="1" style="swimlane;startSize=25;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" value="过滤器与拦截器" vertex="1">
          <mxGeometry height="250" width="660" x="700" y="60" as="geometry" />
        </mxCell>
        <mxCell id="XssFilter" parent="filter_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;XssFilter&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements Filter&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ doFilter(request, response, chain)&lt;br&gt;&lt;small&gt;包装请求体&lt;br&gt;过滤HTML/JS注入字符&lt;br&gt;XssHttpServletRequestWrapper&lt;/small&gt;" vertex="1">
          <mxGeometry height="120" width="200" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="XssWrapper" parent="filter_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;XssHttpServletRequestWrapper&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends HttpServletRequestWrapper&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ getParameter() : String&lt;br&gt;+ getParameterValues() : String[]&lt;br&gt;+ getInputStream() : ServletInputStream&lt;br&gt;&lt;small&gt;清理请求参数中的XSS代码&lt;/small&gt;" vertex="1">
          <mxGeometry height="130" width="220" x="220" y="35" as="geometry" />
        </mxCell>
        <mxCell id="SaInterceptor" parent="filter_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;SaTokenConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration implements WebMvcConfigurer&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ addInterceptors(registry)&lt;br&gt;&lt;small&gt;注册 Sa-Token 拦截器&lt;br&gt;POST/PUT/DELETE/PATCH 需登录&lt;br&gt;GET 公开 (白名单排除)&lt;br&gt;/api/admin/** 需admin角色&lt;/small&gt;" vertex="1">
          <mxGeometry height="150" width="200" x="450" y="35" as="geometry" />
        </mxCell>
        <mxCell id="cache_header" parent="1" style="swimlane;startSize=25;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" value="缓存配置" vertex="1">
          <mxGeometry height="250" width="660" x="20" y="340" as="geometry" />
        </mxCell>
        <mxCell id="CacheConfig" parent="cache_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;CacheConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ cacheManager() : CacheManager&lt;br&gt;&lt;small&gt;TwoLevelCacheManager&lt;br&gt;L1: Caffeine (内存, 1000条, 10min)&lt;br&gt;L2: Redis (分布式, 按实体TTL)&lt;/small&gt;" vertex="1">
          <mxGeometry height="130" width="210" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="TwoLevelCache" parent="cache_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;TwoLevelCacheManager&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements CacheManager&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ getCache(name) : Cache&lt;br&gt;&lt;small&gt;缓存名称映射TTL:&lt;br&gt;plants/knowledges/inheritors: 6h&lt;br&gt;resources: 4h&lt;br&gt;users: 30m&lt;br&gt;quizQuestions: 12h&lt;br&gt;searchResults: 5m&lt;br&gt;hotData: 1h&lt;/small&gt;" vertex="1">
          <mxGeometry height="170" width="200" x="230" y="35" as="geometry" />
        </mxCell>
        <mxCell id="TwoLevelCacheImpl" parent="cache_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;TwoLevelCache&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements Cache&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— caffeineCache : Cache&lt;br&gt;— redisCache : Cache&lt;hr size=&#39;1&#39;&gt;+ get(key) : ValueWrapper&lt;br&gt;+ put(key, value)&lt;br&gt;+ evict(key)&lt;br&gt;&lt;small&gt;先查Caffeine → miss查Redis&lt;br&gt;写入同时更新两级&lt;br&gt;evict同时清除两级&lt;/small&gt;" vertex="1">
          <mxGeometry height="170" width="210" x="440" y="35" as="geometry" />
        </mxCell>
        <mxCell id="mq_header" parent="1" style="swimlane;startSize=25;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" value="消息队列配置" vertex="1">
          <mxGeometry height="250" width="660" x="700" y="340" as="geometry" />
        </mxCell>
        <mxCell id="RabbitMQConfig" parent="mq_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;RabbitMQConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ 5个Queue定义&lt;br&gt;+ 5个Exchange定义&lt;br&gt;+ 5个Binding定义&lt;br&gt;&lt;small&gt;operation.log.queue&lt;br&gt;statistics.update.queue&lt;br&gt;feedback.process.queue&lt;br&gt;file.process.queue&lt;br&gt;notification.queue&lt;/small&gt;" vertex="1">
          <mxGeometry height="170" width="200" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="MqProducer" parent="mq_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;MqProducer&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Component&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— rabbitTemplate : RabbitTemplate&lt;hr size=&#39;1&#39;&gt;+ sendOperationLog(log)&lt;br&gt;+ sendStatisticsUpdate(type, id)&lt;br&gt;+ sendFeedbackProcess(feedback)&lt;br&gt;+ sendFileProcess(file)&lt;br&gt;+ sendNotification(notification)" vertex="1">
          <mxGeometry height="160" width="210" x="220" y="35" as="geometry" />
        </mxCell>
        <mxCell id="MqConsumers" parent="mq_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;MqConsumers&lt;/b&gt;&lt;br&gt;&lt;i&gt;5个 @RabbitListener&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ OperationLogConsumer&lt;br&gt;+ StatisticsConsumer&lt;br&gt;+ FeedbackConsumer&lt;br&gt;+ FileProcessConsumer&lt;br&gt;+ NotificationConsumer&lt;br&gt;&lt;small&gt;异步处理各业务逻辑&lt;/small&gt;" vertex="1">
          <mxGeometry height="150" width="200" x="440" y="35" as="geometry" />
        </mxCell>
        <mxCell id="ws_header" parent="1" style="swimlane;startSize=25;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" value="WebSocket 配置" vertex="1">
          <mxGeometry height="200" width="660" x="20" y="620" as="geometry" />
        </mxCell>
        <mxCell id="WebSocketConfig" parent="ws_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;WebSocketConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ registerWebSocketHandlers(registry)&lt;br&gt;&lt;small&gt;注册 /ws/chat 端点&lt;br&gt;配置跨域策略&lt;/small&gt;" vertex="1">
          <mxGeometry height="100" width="200" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="ChatWebSocketHandler" parent="ws_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;ChatWebSocketHandler&lt;/b&gt;&lt;br&gt;&lt;i&gt;extends TextWebSocketHandler&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— deepSeekClient : DeepSeekClient&lt;br&gt;— chatHistoryService : ChatHistoryService&lt;hr size=&#39;1&#39;&gt;+ afterConnectionEstablished(session)&lt;br&gt;+ handleTextMessage(session, message)&lt;br&gt;+ afterConnectionClosed(session, status)&lt;br&gt;&lt;small&gt;JWT认证 → 保存历史 → SSE流式调用AI&lt;/small&gt;" vertex="1">
          <mxGeometry height="160" width="240" x="220" y="35" as="geometry" />
        </mxCell>
        <mxCell id="static_header" parent="1" style="swimlane;startSize=25;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontStyle=1;fontSize=13;" value="其他配置" vertex="1">
          <mxGeometry height="200" width="660" x="700" y="620" as="geometry" />
        </mxCell>
        <mxCell id="WebMvcConfig" parent="static_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;WebMvcConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ addResourceHandlers(registry)&lt;br&gt;&lt;small&gt;静态资源映射&lt;br&gt;/images/** → uploadDir&lt;br&gt;/kkfileview/** → 文件预览&lt;/small&gt;" vertex="1">
          <mxGeometry height="110" width="200" x="10" y="35" as="geometry" />
        </mxCell>
        <mxCell id="SwaggerConfig" parent="static_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;SwaggerConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ api() : OpenAPI&lt;br&gt;&lt;small&gt;SpringDoc/OpenAPI 配置&lt;br&gt;Swagger UI: /swagger-ui.html&lt;/small&gt;" vertex="1">
          <mxGeometry height="100" width="200" x="220" y="35" as="geometry" />
        </mxCell>
        <mxCell id="CorsConfig" parent="static_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;CorsConfig&lt;/b&gt;&lt;br&gt;&lt;i&gt;@Configuration&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ corsFilter() : CorsFilter&lt;br&gt;&lt;small&gt;跨域配置&lt;br&gt;允许前端 localhost:5173&lt;/small&gt;" vertex="1">
          <mxGeometry height="100" width="200" x="430" y="35" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
