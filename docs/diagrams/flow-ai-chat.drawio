<mxfile host="app.diagrams.net">
  <diagram name="AI智能对话流程" id="flow-ai-chat">
    <mxGraphModel dx="1076" dy="594" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
