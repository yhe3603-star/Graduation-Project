        </mxCell>
        <mxCell id="f3" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="加载历史消息&#xa;GET /api/chat-history/sessions/{id}" vertex="1">
          <mxGeometry height="40" width="200" x="590" y="295" as="geometry" />
        </mxCell>
        <mxCell id="ws_box" parent="1" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;rounded=1;" value="WebSocket连接建立" vertex="1">
          <mxGeometry height="140" width="260" x="350" y="430" as="geometry" />
        </mxCell>
        <mxCell id="ws1" parent="ws_box" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" value="ws://host/ws/chat?token=xxx" vertex="1">
          <mxGeometry height="25" width="160" x="10" y="25" as="geometry" />
        </mxCell>
        <mxCell id="ws2" parent="ws_box" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" value="Sa-Token鉴权(从URL参数)" vertex="1">
          <mxGeometry height="25" width="160" x="10" y="55" as="geometry" />
        </mxCell>
        <mxCell id="ws3" parent="ws_box" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" value="连接失败→指数退避重试&#xa;(最多5次: 1s/2s/4s/8s/16s)" vertex="1">
          <mxGeometry height="30" width="240" x="10" y="85" as="geometry" />
        </mxCell>
