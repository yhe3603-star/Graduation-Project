<mxfile host="app.diagrams.net">
  <diagram name="AI智能问诊流程" id="flow-ai-chat">
    <mxGraphModel dx="1076" dy="594" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="AI智能问诊流程" vertex="1">
          <mxGeometry height="35" width="300" x="320" y="10" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;fillColor=#6c8ebf;fontColor=#fff;" value="开始" vertex="1">
          <mxGeometry height="40" width="80" x="440" y="60" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="已登录?" vertex="1">
          <mxGeometry height="60" width="120" x="420" y="130" as="geometry" />
        </mxCell>
        <mxCell id="f0" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="跳转登录页&#xa;?redirect=/qa&amp;needLogin=true" vertex="1">
          <mxGeometry height="45" width="170" x="210" y="137.5" as="geometry" />
        </mxCell>
        <mxCell id="f1" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="进入问答页(/qa)的AI问诊侧边栏&#xa;(AiChatCard.vue嵌入Qa.vue)" vertex="1">
          <mxGeometry height="40" width="190" x="385" y="220" as="geometry" />
        </mxCell>
        <mxCell id="d2" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="选择会话?" vertex="1">
          <mxGeometry height="60" width="120" x="420" y="290" as="geometry" />
        </mxCell>
        <mxCell id="f2" parent="1" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="新建会话&#xa;生成UUID sessionId" vertex="1">
