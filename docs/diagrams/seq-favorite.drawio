<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="收藏切换时序图" id="seq-favorite">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="收藏切换时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Sa-Token&lt;br&gt;Interceptor&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Favorite&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Favorite&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Favorite&lt;br&gt;Mapper&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="POST /api/favorites {targetType, targetId}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="校验 Token (POST需登录)" style="html=1;fontSize=10;" edge="1" source="p2" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="150" as="sourcePoint"/><mxPoint y="150" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="转发请求 (附带userId)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="toggleFavorite(userId, targetType, targetId)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="210" as="sourcePoint"/><mxPoint y="210" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt1" value="alt" style="swimlane;startSize=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="490" y="225" width="270" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="alt1_guard" value="[已收藏 → 取消]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="20" width="120" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="查询现有收藏" style="html=1;fontSize=10;" edge="1" source="p4" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="270" as="sourcePoint"/><mxPoint y="270" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5b" value="SELECT * FROM favorites WHERE user_id=? AND target_type=? AND target_id=?" style="html=1;fontSize=9;" edge="1" source="p5" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="290" as="sourcePoint"/><mxPoint y="290" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5c" value="返回记录" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="310" as="sourcePoint"/><mxPoint y="310" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="DELETE FROM favorites WHERE id=?" style="html=1;fontSize=10;" edge="1" source="p5" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="340" as="sourcePoint"/><mxPoint y="340" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="alt1_else" value="[未收藏 → 添加]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="130" width="120" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="m7" value="INSERT INTO favorites" style="html=1;fontSize=10;" edge="1" source="p5" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="440" as="sourcePoint"/><mxPoint y="440" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="返回 {favorited: true/false}" style="html=1;fontSize=10;dashed=1;" edge="1" source="p4" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="470" as="sourcePoint"/><mxPoint y="470" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="返回 R.ok({favorited})" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="500" as="sourcePoint"/><mxPoint y="500" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
