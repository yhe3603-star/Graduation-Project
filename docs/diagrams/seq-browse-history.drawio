<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="浏览记录时序图" id="seq-browse-history">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="浏览记录时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;BrowseHistory&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;BrowseHistory&lt;br&gt;Mapper&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;MQ&lt;br&gt;Producer&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="500" as="geometry"/>
        </mxCell>

        <!-- Record browse history -->
        <mxCell id="m1" value="用户浏览植物/知识/传承人详情" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="record(userId, targetType, targetId)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="150" as="sourcePoint"/><mxPoint y="150" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="检查今日是否已记录 (去重)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3b" value="SELECT COUNT(*) FROM browse_history WHERE user_id=? AND target_type=? AND target_id=? AND DATE(created_at)=CURDATE()" style="html=1;fontSize=8;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="200" as="sourcePoint"/><mxPoint y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3c" value="返回 count" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="220" as="sourcePoint"/><mxPoint y="220" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt1" value="alt" style="swimlane;startSize=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="235" width="420" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="alt1_guard" value="[count == 0 → 首次浏览]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="20" width="150" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="INSERT INTO browse_history" style="html=1;fontSize=10;" edge="1" source="p4" target="p6" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="alt1_else" value="[count > 0 → 已记录，跳过]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="90" width="150" height="20" as="geometry"/>
        </mxCell>

        <!-- Query browse history -->
        <mxCell id="m5" value="GET /api/browse-history?page=1&amp;size=10" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="390" as="sourcePoint"/><mxPoint y="390" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="list(userId, page, size)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="410" as="sourcePoint"/><mxPoint y="410" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="SELECT * FROM browse_history WHERE user_id=? ORDER BY created_at DESC LIMIT ? OFFSET ?" style="html=1;fontSize=8;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="430" as="sourcePoint"/><mxPoint y="430" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="返回分页结果" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="450" as="sourcePoint"/><mxPoint y="450" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="返回 R.ok(pageResult)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="470" as="sourcePoint"/><mxPoint y="470" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="返回浏览记录列表" style="html=1;fontSize=10;dashed=1;" edge="1" source="p2" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="490" as="sourcePoint"/><mxPoint y="490" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
