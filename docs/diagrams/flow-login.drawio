        <mxCell id="f4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="密码错误/用户不存在&lt;br&gt;返回错误信息" vertex="1">
