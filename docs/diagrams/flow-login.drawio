        <mxCell id="f3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="POST /api/user/login&lt;br&gt;@RateLimit(5)" vertex="1">
