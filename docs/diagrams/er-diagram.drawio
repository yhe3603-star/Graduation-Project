        <mxCell id="plants" parent="domain_content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;plants (药用植物)&lt;/b&gt;&lt;hr size=&#39;1&#39;&gt;PK id INT AUTO_INCREMENT&lt;br&gt;name_cn VARCHAR(100)&lt;br&gt;name_dong VARCHAR(100)&lt;br&gt;scientific_name VARCHAR(200)&lt;br&gt;category VARCHAR(20)&lt;br&gt;usage_way VARCHAR(20)&lt;br&gt;habitat VARCHAR(200)&lt;br&gt;efficacy VARCHAR(500)&lt;br&gt;story VARCHAR(2000)&lt;br&gt;images/videos/documents TEXT&lt;br&gt;distribution TEXT&lt;br&gt;difficulty VARCHAR(20)&lt;br&gt;update_log TEXT&lt;br&gt;view_count INT&lt;br&gt;favorite_count INT&lt;br&gt;popularity INT&lt;br&gt;created_at/updated_at DATETIME" vertex="1">
