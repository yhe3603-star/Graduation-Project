        <mxCell id="inheritors" parent="domain_content" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;inheritors (传承人)&lt;/b&gt;&lt;hr size=&#39;1&#39;&gt;PK id INT AUTO_INCREMENT&lt;br&gt;name VARCHAR(50)&lt;br&gt;level VARCHAR(20)&lt;br&gt;bio VARCHAR(1000)&lt;br&gt;specialties VARCHAR(500)&lt;br&gt;experience_years INT&lt;br&gt;videos/images/documents TEXT&lt;br&gt;representative_cases TEXT&lt;br&gt;honors VARCHAR(1000)&lt;br&gt;update_log TEXT&lt;br&gt;view_count INT&lt;br&gt;favorite_count INT&lt;br&gt;popularity INT" vertex="1">
