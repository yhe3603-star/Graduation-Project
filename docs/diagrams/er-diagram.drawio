        <mxCell id="r_ubh" edge="1" parent="1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;strokeColor=#333;fontSize=10;fontStyle=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="browse_history" value="1 : N">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="288" />
