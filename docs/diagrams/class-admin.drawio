<mxfile host="app.diagrams.net">
  <diagram name="后台管理Controller" id="class-ctrl-admin">
    <mxGraphModel dx="1202" dy="664" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="Controller层类图 — 后台管理 (3/4)" vertex="1">
          <mxGeometry height="35" width="400" x="190" y="10" as="geometry" />
        </mxCell>
        <mxCell id="AdminUserController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;AdminUserController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— userService : UserService&lt;hr size=&#39;1&#39;&gt;+ listUsers(page, size) : R&lt;Map&gt;&lt;br&gt;+ deleteUser(id) : R&lt;String&gt;&lt;br&gt;+ updateUserRole(id, role) : R&lt;String&gt;&lt;br&gt;+ banUser(id, reason) : R&lt;String&gt;&lt;br&gt;+ unbanUser(id) : R&lt;String&gt;" vertex="1">
          <mxGeometry height="160" width="170" x="285" y="435" as="geometry" />
        </mxCell>
        <mxCell id="AdminContentController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;AdminContentController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— plantService, knowledgeService,&lt;br&gt;  inheritorService, resourceService,&lt;br&gt;  qaService&lt;hr size=&#39;1&#39;&gt;&lt;b&gt;每个实体5个端点:&lt;/b&gt;&lt;br&gt;+ list{Entity}(page, size) : R&lt;Map&gt;&lt;br&gt;+ create{Entity}(dto) : R&lt;String&gt;&lt;br&gt;+ update{Entity}(id, dto) : R&lt;String&gt;&lt;br&gt;+ delete{Entity}(id) : R&lt;String&gt;&lt;br&gt;&lt;small&gt;覆盖: Plants/Knowledge/Inheritors/Resources/Qa&lt;/small&gt;" vertex="1">
          <mxGeometry height="200" width="210" x="270" y="60" as="geometry" />
        </mxCell>
        <mxCell id="AdminInteractionController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;AdminInteractionController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— feedbackService, commentService&lt;hr size=&#39;1&#39;&gt;+ listFeedback(status, page, size) : R&lt;Map&gt;&lt;br&gt;+ replyFeedback(id, dto) : R&lt;String&gt;&lt;br&gt;+ deleteFeedback(id) : R&lt;String&gt;&lt;br&gt;+ listComments(status, page, size) : R&lt;Map&gt;&lt;br&gt;+ approveComment(id) : R&lt;String&gt;&lt;br&gt;+ rejectComment(id) : R&lt;String&gt;&lt;br&gt;+ deleteComment(id) : R&lt;String&gt;" vertex="1">
          <mxGeometry height="190" width="210" x="500" y="65" as="geometry" />
        </mxCell>
        <mxCell id="AdminStatsController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;AdminStatsController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— statsService : StatsService&lt;hr size=&#39;1&#39;&gt;+ stats() : R&lt;Map&lt;String, Long&gt;&gt;&lt;br&gt;+ getUserGrowth() : R&lt;Map&gt;&lt;br&gt;+ getContentViews() : R&lt;List&gt;&lt;br&gt;+ getSearchKeywords() : R&lt;List&gt;" vertex="1">
          <mxGeometry height="150" width="180" x="510" y="285" as="geometry" />
        </mxCell>
        <mxCell id="OperationLogController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;OperationLogController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin/logs&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— operationLogService : OperationLogService&lt;hr size=&#39;1&#39;&gt;+ list(module, type, username, limit) : R&lt;List&gt;&lt;br&gt;+ getById(id) : R&lt;OperationLog&gt;&lt;br&gt;+ delete(id) : R&lt;String&gt;&lt;br&gt;+ batchDelete(ids) : R&lt;String&gt;&lt;br&gt;+ clearAll() : R&lt;String&gt;&lt;br&gt;+ stats() : R&lt;Map&gt;" vertex="1">
          <mxGeometry height="180" width="225" x="30" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ExportController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;ExportController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/admin/export&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckRole(&quot;admin&quot;)&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— exportService : ExportService&lt;hr size=&#39;1&#39;&gt;+ export(entity, format, response) : void&lt;br&gt;&lt;small&gt;支持CSV格式导出各实体数据&lt;/small&gt;" vertex="1">
