        <mxCell id="legend" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b&gt;图例&lt;/b&gt;&lt;hr size=&#39;1&#39;&gt;&lt;font color=&#39;#6c8ebf&#39;&gt;■&lt;/font&gt; 内容展示 Controller (公开接口)&lt;br&gt;&lt;font color=&#39;#82b366&#39;&gt;■&lt;/font&gt; 用户功能 Controller&lt;br&gt;&lt;font color=&#39;#d6b656&#39;&gt;■&lt;/font&gt; 混合权限 Controller&lt;br&gt;&lt;font color=&#39;#b85450&#39;&gt;■&lt;/font&gt; 后台管理 Controller (@SaCheckRole)&lt;br&gt;&lt;font color=&#39;#d79b00&#39;&gt;■&lt;/font&gt; AI/特殊 Controller&lt;hr size=&#39;1&#39;&gt;&lt;small&gt;共27个Controller, 119个REST端点&lt;/small&gt;&lt;br&gt;&lt;small&gt;GET:75 POST:29 PUT:12 DELETE:13&lt;/small&gt;" vertex="1">
