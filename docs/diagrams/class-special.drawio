  <diagram name="AI与特殊Controller" id="class-ctrl-special">
    <mxGraphModel dx="1022" dy="564" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="Controller层类图 — AI与特殊组件 (4/4)" vertex="1">
          <mxGeometry height="35" width="400" x="50" y="10" as="geometry" />
        </mxCell>
        <mxCell id="ChatWebSocketHandler" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;ChatWebSocketHandler&lt;/b&gt;&lt;br&gt;&lt;i&gt;WebSocket /ws/chat?token=xxx&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— deepSeekClient : DeepSeekClient&lt;br&gt;— chatHistoryService : ChatHistoryService&lt;hr size=&#39;1&#39;&gt;+ afterConnectionEstablished(session)&lt;br&gt;+ handleTextMessage(session, message)&lt;br&gt;+ afterConnectionClosed(status)&lt;br&gt;+ handleTransportError(exception)&lt;hr size=&#39;1&#39;&gt;&lt;small&gt;消息类型: chat/stop&lt;/small&gt;&lt;br&gt;&lt;small&gt;SSE流式输出AI回复&lt;/small&gt;&lt;br&gt;&lt;small&gt;鉴权: 从URL参数提取Sa-Token&lt;/small&gt;" vertex="1">
          <mxGeometry height="200" width="220" x="30" y="60" as="geometry" />
        </mxCell>
        <mxCell id="ChatHistoryController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;ChatHistoryController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/chat-history&lt;/i&gt;&lt;br&gt;&lt;i&gt;@SaCheckLogin&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— chatHistoryService : ChatHistoryService&lt;hr size=&#39;1&#39;&gt;+ listSessions() : R&lt;List&gt;&lt;br&gt;+ getSessionMessages(sessionId) : R&lt;List&gt;&lt;br&gt;+ deleteSession(sessionId) : R&lt;String&gt;" vertex="1">
          <mxGeometry height="130" width="210" x="270" y="70" as="geometry" />
        </mxCell>
        <mxCell id="ChatController" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:12px&#39;&gt;ChatController&lt;/b&gt;&lt;br&gt;&lt;i&gt;@RestController /api/chat&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;+ stats() : R&lt;ChatStats&gt;&lt;hr size=&#39;1&#39;&gt;&lt;small&gt;ChatStats(totalRequests,&lt;br&gt;  successRequests, failedRequests)&lt;/small&gt;" vertex="1">
          <mxGeometry height="110" width="160" x="30" y="280" as="geometry" />
