        <mxCell id="a6" parent="auth_box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" value="Token验证&lt;br&gt;&lt;small&gt;GET /api/user/validate&lt;/small&gt;" vertex="1">
