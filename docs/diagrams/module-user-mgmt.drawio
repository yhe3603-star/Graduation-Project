        <mxCell id="d1" parent="auth_detail" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=9;" value="BCrypt密码加密&lt;br&gt;&lt;small&gt;注册时hash/登录时matches&lt;/small&gt;" vertex="1">
