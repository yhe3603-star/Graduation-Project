        <mxCell id="a1" parent="auth_box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" value="用户注册&lt;br&gt;&lt;small&gt;POST /api/user/register&lt;/small&gt;" vertex="1">
