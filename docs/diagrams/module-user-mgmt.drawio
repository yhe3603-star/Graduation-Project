<mxfile host="app.diagrams.net">
  <diagram name="用户管理模块" id="mod-user-mgmt">
    <mxGraphModel dx="1022" dy="564" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="用户管理模块 — 功能详细" vertex="1">
          <mxGeometry height="30" width="400" x="140" y="10" as="geometry" />
        </mxCell>
        <mxCell id="auth_box" parent="1" style="swimlane;startSize=25;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;rounded=1;" value="认证系统 — UserController" vertex="1">
          <mxGeometry height="280" width="340" x="20" y="60" as="geometry" />
