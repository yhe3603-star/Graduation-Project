        </mxCell>
        <mxCell id="u_f5" parent="1" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;" value="INSERT INTO feedback&#xa;status=&#39;pending&#39;" vertex="1">
