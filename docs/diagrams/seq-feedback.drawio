<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="反馈提交时序图" id="seq-feedback">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="用户反馈提交时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Sa-Token&lt;br&gt;Interceptor&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Feedback&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Feedback&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;MQ&lt;br&gt;Producer&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="550" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="550" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="POST /api/feedback {type, content, contact}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="校验 Token (POST需登录)" style="html=1;fontSize=10;" edge="1" source="p2" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="150" as="sourcePoint"/><mxPoint y="150" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="转发请求 (附带userId)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="submitFeedback(userId, FeedbackDTO)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="210" as="sourcePoint"/><mxPoint y="210" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="XSS 过滤内容" style="html=1;fontSize=10;" edge="1" source="p4" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="240" as="sourcePoint"/><mxPoint y="240" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="INSERT INTO feedback (status='pending')" style="html=1;fontSize=10;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="270" as="sourcePoint"/><mxPoint y="270" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="发送MQ通知 (通知管理员)" style="html=1;fontSize=10;" edge="1" source="p4" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="300" as="sourcePoint"/><mxPoint y="300" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="返回反馈对象" style="html=1;fontSize=10;dashed=1;" edge="1" source="p4" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="330" as="sourcePoint"/><mxPoint y="330" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="返回 R.ok(feedback)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="360" as="sourcePoint"/><mxPoint y="360" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="显示提交成功提示" style="html=1;fontSize=10;" edge="1" source="p1" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="390" as="sourcePoint"/><mxPoint y="390" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Admin processes feedback -->
        <mxCell id="ref1" value="ref [管理员回复后]" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="410" width="670" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="m11" value="GET /api/feedback/my" style="html=1;fontSize=10;" edge="1" source="p1" target="p3" parent="ref1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="50" as="sourcePoint"/><mxPoint y="50" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" value="SELECT * FROM feedback WHERE user_id=? ORDER BY created_at DESC" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="ref1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="80" as="sourcePoint"/><mxPoint y="80" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m13" value="返回反馈列表 (含管理员回复)" style="html=1;fontSize=9;dashed=1;" edge="1" source="p3" target="p1" parent="ref1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="110" as="sourcePoint"/><mxPoint y="110" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
