        <mxCell id="CommentService" parent="svc_header" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;align=left;verticalAlign=top;spacingLeft=8;spacingTop=5;" value="&lt;b style=&#39;font-size:11px&#39;&gt;CommentServiceImpl&lt;/b&gt;&lt;br&gt;&lt;i&gt;implements CommentService&lt;/i&gt;&lt;hr size=&#39;1&#39;&gt;— commentMapper : CommentMapper&lt;br&gt;— mqProducer : MqProducer&lt;hr size=&#39;1&#39;&gt;+ addComment(comment) : void&lt;br&gt;+ listApproved(targetType, targetId) : List&amp;lt;CommentDTO&amp;gt;&lt;br&gt;+ listApprovedPaged(targetType, targetId, page, size) : Page&amp;lt;CommentDTO&amp;gt;&lt;br&gt;+ listByUserIdPaged(userId, page, size) : Page&amp;lt;CommentDTO&amp;gt;&lt;br&gt;+ approveComment(id) : void&lt;br&gt;+ rejectComment(id) : void&lt;br&gt;+ pageAllDTO(status, page, size) : Page&amp;lt;CommentDTO&amp;gt;" vertex="1">
