<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="用户登录时序图" id="seq-login">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="用户登录时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="80" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Nginx&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="230" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="380" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="530" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Sa-Token&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="680" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="830" y="50" width="100" height="560" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="POST /api/user/login {username, password}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="转发请求" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="140" as="sourcePoint"/><mxPoint y="140" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="login(username, password)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="160" as="sourcePoint"/><mxPoint y="160" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="查询用户: SELECT * FROM users WHERE username=?" style="html=1;fontSize=10;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="返回 User 对象" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p4" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="210" as="sourcePoint"/><mxPoint y="210" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="BCrypt.matches(password, hash)" style="html=1;fontSize=10;" edge="1" source="p4" target="p4" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="240" as="sourcePoint"/><mxPoint y="240" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="检查 status != banned" style="html=1;fontSize=10;" edge="1" source="p4" target="p4" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="270" as="sourcePoint"/><mxPoint y="270" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="StpUtil.login(userId)" style="html=1;fontSize=10;" edge="1" source="p4" target="p5" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="300" as="sourcePoint"/><mxPoint y="300" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="生成 JWT Token" style="html=1;fontSize=10;" edge="1" source="p5" target="p5" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="330" as="sourcePoint"/><mxPoint y="330" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="返回 TokenValue" style="html=1;fontSize=10;dashed=1;" edge="1" source="p5" target="p4" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="350" as="sourcePoint"/><mxPoint y="350" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" value="返回 R.ok({token, user})" style="html=1;fontSize=10;dashed=1;" edge="1" source="p4" target="p3" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="370" as="sourcePoint"/><mxPoint y="370" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" value="返回 200 {code:0, data:{token,user}}" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p2" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="390" as="sourcePoint"/><mxPoint y="390" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m13" value="返回响应" style="html=1;fontSize=10;dashed=1;" edge="1" source="p2" target="p1" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="410" as="sourcePoint"/><mxPoint y="410" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m14" value="存储 Token 到 localStorage" style="html=1;fontSize=10;" edge="1" source="p1" target="p1" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="440" as="sourcePoint"/><mxPoint y="440" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m15" value="后续请求 Header: Authorization: Bearer {token}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry x="-0.1" relative="1" as="geometry"><mxPoint y="470" as="sourcePoint"/><mxPoint y="470" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
