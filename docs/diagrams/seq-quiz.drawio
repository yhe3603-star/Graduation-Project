<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="答题提交时序图" id="seq-quiz">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="答题提交与判分时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Sa-Token&lt;br&gt;Interceptor&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Quiz&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Quiz&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Cache&lt;br&gt;(L1+L2)&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="600" as="geometry"/>
        </mxCell>

        <!-- Step 1: Load quiz questions -->
        <mxCell id="m1" value="GET /api/quiz/questions" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="转发请求 (GET公开)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="140" as="sourcePoint"/><mxPoint y="140" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="getRandomQuestions(count)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="160" as="sourcePoint"/><mxPoint y="160" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m4" value="查询二级缓存: quizQuestions" style="html=1;fontSize=10;" edge="1" source="p4" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="SELECT * FROM quiz_questions ORDER BY RAND() LIMIT ?" style="html=1;fontSize=9;" edge="1" source="p5" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="210" as="sourcePoint"/><mxPoint y="210" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="返回题目列表" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="230" as="sourcePoint"/><mxPoint y="230" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="写入缓存 (TTL=12h)" style="html=1;fontSize=10;" edge="1" source="p5" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="250" as="sourcePoint"/><mxPoint y="250" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="返回题目列表 (不含答案)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p5" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="270" as="sourcePoint"/><mxPoint y="270" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="返回 R.ok(questions)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p4" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="290" as="sourcePoint"/><mxPoint y="290" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="返回题目列表" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="310" as="sourcePoint"/><mxPoint y="310" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 2: User answers questions on frontend -->
        <mxCell id="self1" value="用户逐题作答 (前端计时)" style="html=1;fontSize=10;" edge="1" source="p1" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="340" as="sourcePoint"/><mxPoint y="340" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Step 3: Submit answers -->
        <mxCell id="m11" value="POST /api/quiz/submit {answers[], totalTime}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="380" as="sourcePoint"/><mxPoint y="380" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" value="校验 Token" style="html=1;fontSize=10;" edge="1" source="p2" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="400" as="sourcePoint"/><mxPoint y="400" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m13" value="转发请求 (附带userId)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="420" as="sourcePoint"/><mxPoint y="420" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m14" value="submitQuiz(userId, answers, totalTime)" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="450" as="sourcePoint"/><mxPoint y="450" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m15" value="逐题比对答案判分" style="html=1;fontSize=10;" edge="1" source="p4" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="480" as="sourcePoint"/><mxPoint y="480" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m16" value="SELECT correct_answer FROM quiz_questions WHERE id IN (...)" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="510" as="sourcePoint"/><mxPoint y="510" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m17" value="返回正确答案" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="530" as="sourcePoint"/><mxPoint y="530" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m18" value="INSERT INTO quiz_record (score, correctCount, totalTime)" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="560" as="sourcePoint"/><mxPoint y="560" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m19" value="返回 {score, correctCount, totalTime, details[]}" style="html=1;fontSize=9;dashed=1;" edge="1" source="p4" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="590" as="sourcePoint"/><mxPoint y="590" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m20" value="返回 R.ok(result)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p3" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="620" as="sourcePoint"/><mxPoint y="620" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
