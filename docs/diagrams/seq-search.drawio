<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="搜索时序图" id="seq-search">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="综合搜索时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Search&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Search&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;*Mapper&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Cache&lt;br&gt;(L1+L2)&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="600" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="GET /api/search?keyword=xxx&amp;type=all" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m2" value="search(keyword, type, page, size)" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="150" as="sourcePoint"/><mxPoint y="150" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Check cache first -->
        <mxCell id="m3" value="查询缓存: searchResults:{keyword}:{type}" style="html=1;fontSize=10;" edge="1" source="p3" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="180" as="sourcePoint"/><mxPoint y="180" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt1" value="alt" style="swimlane;startSize=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="340" y="195" width="420" height="300" as="geometry"/>
        </mxCell>
        <mxCell id="alt1_guard" value="[缓存命中]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="20" width="80" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m4" value="直接返回缓存结果" style="html=1;fontSize=10;dashed=1;" edge="1" source="p5" target="p3" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt1_else" value="[缓存未命中 → 多表并行查询]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="90" width="180" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m5" value="LIKE查询植物表" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5b" value="SELECT * FROM plants WHERE name LIKE '%keyword%'" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="140" as="sourcePoint"/><mxPoint y="140" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="LIKE查询知识表" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="170" as="sourcePoint"/><mxPoint y="170" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6b" value="SELECT * FROM knowledge WHERE title LIKE '%keyword%'" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="190" as="sourcePoint"/><mxPoint y="190" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="LIKE查询传承人表" style="html=1;fontSize=10;" edge="1" source="p3" target="p4" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="220" as="sourcePoint"/><mxPoint y="220" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7b" value="SELECT * FROM inheritors WHERE name LIKE '%keyword%'" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="240" as="sourcePoint"/><mxPoint y="240" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="写入缓存 (TTL=5m)" style="html=1;fontSize=10;" edge="1" source="p3" target="p5" parent="alt1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="270" as="sourcePoint"/><mxPoint y="270" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="m9" value="合并结果按热度排序" style="html=1;fontSize=10;" edge="1" source="p3" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="520" as="sourcePoint"/><mxPoint y="520" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="返回 R.ok({plants[], knowledges[], inheritors[]})" style="html=1;fontSize=9;dashed=1;" edge="1" source="p3" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="550" as="sourcePoint"/><mxPoint y="550" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m11" value="返回搜索结果" style="html=1;fontSize=10;dashed=1;" edge="1" source="p2" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="580" as="sourcePoint"/><mxPoint y="580" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" value="渲染结果列表 (分类展示)" style="html=1;fontSize=10;" edge="1" source="p1" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="610" as="sourcePoint"/><mxPoint y="610" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
