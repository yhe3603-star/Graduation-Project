<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="植物详情查看时序图" id="seq-plant-detail">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="植物详情查看时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Plant&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Popularity&lt;br&gt;AsyncService&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;Plant&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;Browse&lt;br&gt;History&lt;br&gt;Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;Cache&lt;br&gt;(L1+L2)&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="p7" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f5f5f5;strokeColor=#666;size=40;" vertex="1" parent="1">
          <mxGeometry x="950" y="50" width="100" height="560" as="geometry"/>
        </mxCell>

        <mxCell id="m1" value="GET /api/plants/{id}" style="html=1;fontSize=10;" edge="1" source="p1" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt1" value="alt" style="swimlane;startSize=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="330" y="135" width="420" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="alt1_guard" value="[try]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="20" width="40" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m2" value="incrementPlantViewAndPopularity(id) @Async" style="html=1;fontSize=10;" edge="1" source="p2" target="p3" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="170" as="sourcePoint"/><mxPoint y="170" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3" value="UPDATE plants SET view_count+1, popularity+3" style="html=1;fontSize=10;" edge="1" source="p3" target="p7" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="200" as="sourcePoint"/><mxPoint y="200" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m3b" value="清除缓存" style="html=1;fontSize=10;" edge="1" source="p3" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="230" as="sourcePoint"/><mxPoint y="230" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="alt1_else" value="[catch] 忽略异常" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt1">
          <mxGeometry x="5" y="100" width="100" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="m4" value="getDetailWithStory(id)" style="html=1;fontSize=10;" edge="1" source="p2" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="290" as="sourcePoint"/><mxPoint y="290" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m5" value="查询二级缓存: Caffeine → Redis → DB" style="html=1;fontSize=10;" edge="1" source="p4" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="320" as="sourcePoint"/><mxPoint y="320" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m6" value="SELECT * FROM plants WHERE id=?" style="html=1;fontSize=10;" edge="1" source="p6" target="p7" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="350" as="sourcePoint"/><mxPoint y="350" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m7" value="返回 Plant" style="html=1;fontSize=10;dashed=1;" edge="1" source="p7" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="370" as="sourcePoint"/><mxPoint y="370" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m8" value="写入 L1+L2 缓存" style="html=1;fontSize=10;" edge="1" source="p6" target="p6" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="390" as="sourcePoint"/><mxPoint y="390" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m9" value="返回 Plant (含 story)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p6" target="p4" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="410" as="sourcePoint"/><mxPoint y="410" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m10" value="返回 Plant" style="html=1;fontSize=10;dashed=1;" edge="1" source="p4" target="p2" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="430" as="sourcePoint"/><mxPoint y="430" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="alt2" value="alt" style="swimlane;startSize=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="445" width="460" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="alt2_guard" value="[userId != null]" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="alt2">
          <mxGeometry x="5" y="20" width="100" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="m11" value="record(userId, 'plant', id)" style="html=1;fontSize=10;" edge="1" source="p2" target="p5" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="480" as="sourcePoint"/><mxPoint y="480" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="m12" value="INSERT INTO browse_history" style="html=1;fontSize=10;" edge="1" source="p5" target="p7" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="500" as="sourcePoint"/><mxPoint y="500" as="targetPoint"/></mxGeometry>
        </mxCell>

        <mxCell id="m13" value="返回 R.ok(plant)" style="html=1;fontSize=10;dashed=1;" edge="1" source="p2" target="p1" parent="1">
          <mxGeometry relative="1" as="geometry"><mxPoint y="550" as="sourcePoint"/><mxPoint y="550" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
