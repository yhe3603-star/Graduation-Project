<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net">
  <diagram name="管理员CRUD时序图" id="seq-admin-crud">
    <mxGraphModel dx="1200" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="管理员内容CRUD时序图" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="300" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="p1" value="&lt;b&gt;浏览器&lt;br&gt;(Admin)&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;" vertex="1" parent="1">
          <mxGeometry x="50" y="50" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="&lt;b&gt;Sa-Token&lt;br&gt;Interceptor&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#f8cecc;strokeColor=#b85450;size=40;" vertex="1" parent="1">
          <mxGeometry x="200" y="50" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="&lt;b&gt;Admin&lt;br&gt;Controller&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;" vertex="1" parent="1">
          <mxGeometry x="350" y="50" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="&lt;b&gt;*Service&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;" vertex="1" parent="1">
          <mxGeometry x="500" y="50" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="&lt;b&gt;MQ&lt;br&gt;Producer&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;" vertex="1" parent="1">
          <mxGeometry x="650" y="50" width="100" height="700" as="geometry"/>
        </mxCell>
        <mxCell id="p6" value="&lt;b&gt;MySQL&lt;/b&gt;" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;fillColor=#ffe6cc;strokeColor=#d79b00;size=40;" vertex="1" parent="1">
          <mxGeometry x="800" y="50" width="100" height="700" as="geometry"/>
        </mxCell>

        <!-- Ref: Create -->
        <mxCell id="ref_create" value="ref 创建内容" style="swimlane;startSize=20;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="120" width="670" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="c1" value="POST /api/admin/plants {name, description, images, ...}" style="html=1;fontSize=9;" edge="1" source="p1" target="p2" parent="ref_create">
          <mxGeometry relative="1" as="geometry"><mxPoint y="40" as="sourcePoint"/><mxPoint y="40" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c2" value="校验 Token + @SaCheckRole('admin')" style="html=1;fontSize=9;" edge="1" source="p2" target="p3" parent="ref_create">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c3" value="create(PlantCreateDTO)" style="html=1;fontSize=9;" edge="1" source="p3" target="p4" parent="ref_create">
          <mxGeometry relative="1" as="geometry"><mxPoint y="80" as="sourcePoint"/><mxPoint y="80" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c4" value="INSERT INTO plants" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="ref_create">
          <mxGeometry relative="1" as="geometry"><mxPoint y="100" as="sourcePoint"/><mxPoint y="100" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="c5" value="返回 R.ok(plant)" style="html=1;fontSize=9;dashed=1;" edge="1" source="p3" target="p1" parent="ref_create">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Ref: Update -->
        <mxCell id="ref_update" value="ref 更新内容" style="swimlane;startSize=20;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="280" width="670" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="u1" value="PUT /api/admin/plants/{id} {name, description, ...}" style="html=1;fontSize=9;" edge="1" source="p1" target="p2" parent="ref_update">
          <mxGeometry relative="1" as="geometry"><mxPoint y="40" as="sourcePoint"/><mxPoint y="40" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="u2" value="校验 Token + @SaCheckRole('admin')" style="html=1;fontSize=9;" edge="1" source="p2" target="p3" parent="ref_update">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="u3" value="update(id, PlantUpdateDTO)" style="html=1;fontSize=9;" edge="1" source="p3" target="p4" parent="ref_update">
          <mxGeometry relative="1" as="geometry"><mxPoint y="80" as="sourcePoint"/><mxPoint y="80" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="u4" value="UPDATE plants SET ... WHERE id=?" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="ref_update">
          <mxGeometry relative="1" as="geometry"><mxPoint y="100" as="sourcePoint"/><mxPoint y="100" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="u5" value="清除缓存" style="html=1;fontSize=9;" edge="1" source="p4" target="p5" parent="ref_update">
          <mxGeometry relative="1" as="geometry"><mxPoint y="120" as="sourcePoint"/><mxPoint y="120" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Ref: Delete -->
        <mxCell id="ref_delete" value="ref 删除内容" style="swimlane;startSize=20;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="440" width="670" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="d1" value="DELETE /api/admin/plants/{id}" style="html=1;fontSize=9;" edge="1" source="p1" target="p2" parent="ref_delete">
          <mxGeometry relative="1" as="geometry"><mxPoint y="40" as="sourcePoint"/><mxPoint y="40" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d2" value="校验 Token + @SaCheckRole('admin')" style="html=1;fontSize=9;" edge="1" source="p2" target="p3" parent="ref_delete">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d3" value="delete(id)" style="html=1;fontSize=9;" edge="1" source="p3" target="p4" parent="ref_delete">
          <mxGeometry relative="1" as="geometry"><mxPoint y="80" as="sourcePoint"/><mxPoint y="80" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="d4" value="DELETE FROM plants WHERE id=?" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="ref_delete">
          <mxGeometry relative="1" as="geometry"><mxPoint y="100" as="sourcePoint"/><mxPoint y="100" as="targetPoint"/></mxGeometry>
        </mxCell>

        <!-- Ref: Batch operations -->
        <mxCell id="ref_batch" value="ref 批量操作 (分页查询)" style="swimlane;startSize=20;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="190" y="580" width="670" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="b1" value="GET /api/admin/plants?page=1&amp;size=10" style="html=1;fontSize=9;" edge="1" source="p1" target="p2" parent="ref_batch">
          <mxGeometry relative="1" as="geometry"><mxPoint y="40" as="sourcePoint"/><mxPoint y="40" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="b2" value="校验 Token + @SaCheckRole('admin')" style="html=1;fontSize=9;" edge="1" source="p2" target="p3" parent="ref_batch">
          <mxGeometry relative="1" as="geometry"><mxPoint y="60" as="sourcePoint"/><mxPoint y="60" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="b3" value="list(page, size, keyword)" style="html=1;fontSize=9;" edge="1" source="p3" target="p4" parent="ref_batch">
          <mxGeometry relative="1" as="geometry"><mxPoint y="80" as="sourcePoint"/><mxPoint y="80" as="targetPoint"/></mxGeometry>
        </mxCell>
        <mxCell id="b4" value="SELECT * FROM plants LIMIT ? OFFSET ?" style="html=1;fontSize=9;" edge="1" source="p4" target="p6" parent="ref_batch">
          <mxGeometry relative="1" as="geometry"><mxPoint y="100" as="sourcePoint"/><mxPoint y="100" as="targetPoint"/></mxGeometry>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
