<mxfile host="app.diagrams.net">
  <diagram name="管理员内容管理流程" id="flow-admin">
    <mxGraphModel dx="889" dy="490" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="text;html=1;fontSize=18;fontStyle=1;align=center;" value="管理员内容管理流程" vertex="1">
          <mxGeometry height="35" width="300" x="330" y="10" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="1" style="ellipse;fillColor=#b85450;fontColor=#fff;" value="开始" vertex="1">
          <mxGeometry height="40" width="80" x="440" y="60" as="geometry" />
        </mxCell>
        <mxCell id="f1" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="管理员登录" vertex="1">
          <mxGeometry height="40" width="140" x="410" y="130" as="geometry" />
        </mxCell>
        <mxCell id="f2" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="@SaCheckRole(&#39;admin&#39;)角色校验" vertex="1">
          <mxGeometry height="40" width="160" x="400" y="200" as="geometry" />
        </mxCell>
        <mxCell id="f3" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="进入后台管理页面" vertex="1">
          <mxGeometry height="40" width="160" x="400" y="270" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="选择操作类型?" vertex="1">
          <mxGeometry height="80" width="160" x="400" y="340" as="geometry" />
        </mxCell>
        <mxCell id="create" parent="1" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="新增内容" vertex="1">
          <mxGeometry height="40" width="120" x="110" y="360" as="geometry" />
        </mxCell>
        <mxCell id="create_detail" parent="1" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="填写表单&lt;br&gt;上传图片/视频/文档&#xa;→ FileService 存储" vertex="1">
          <mxGeometry height="60" width="180" x="80" y="460" as="geometry" />
        </mxCell>
        <mxCell id="create_save" parent="1" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" value="POST /api/admin/{type}&#xa;INSERT INTO DB" vertex="1">
          <mxGeometry height="40" width="170" x="80" y="630" as="geometry" />
        </mxCell>
        <mxCell id="update" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="编辑内容" vertex="1">
          <mxGeometry height="40" width="120" x="300" y="470" as="geometry" />
        </mxCell>
        <mxCell id="update_detail" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="加载现有数据修改后提交" vertex="1">
          <mxGeometry height="40" width="160" x="280" y="540" as="geometry" />
        </mxCell>
        <mxCell id="update_save" parent="1" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="PUT /api/admin/{type}/{id}&#xa;UPDATE DB" vertex="1">
          <mxGeometry height="40" width="180" x="270" y="610" as="geometry" />
        </mxCell>
        <mxCell id="delete" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" value="删除内容" vertex="1">
          <mxGeometry height="40" width="120" x="500" y="470" as="geometry" />
        </mxCell>
        <mxCell id="delete_confirm" parent="1" style="rhombus;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" value="确认删除?" vertex="1">
          <mxGeometry height="60" width="120" x="500" y="540" as="geometry" />
        </mxCell>
        <mxCell id="delete_exec" parent="1" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="DELETE /api/admin/{type}/{id}" vertex="1">
          <mxGeometry height="40" width="180" x="470" y="640" as="geometry" />
        </mxCell>
        <mxCell id="list" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="查看列表" vertex="1">
          <mxGeometry height="40" width="120" x="610" y="360" as="geometry" />
        </mxCell>
        <mxCell id="list_detail" parent="1" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="GET /api/admin/{type}/list&#xa;分页查询 + 搜索" vertex="1">
          <mxGeometry height="40" width="170" x="585" y="420" as="geometry" />
        </mxCell>
        <mxCell id="log" parent="1" style="rounded=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" value="AOP自动记录操作日志→ operation_log 表" vertex="1">
          <mxGeometry height="40" width="200" x="260" y="710" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="1" style="ellipse;fillColor=#b85450;fontColor=#fff;" value="完成" vertex="1">
          <mxGeometry height="40" width="80" x="320" y="770" as="geometry" />
        </mxCell>
        <mxCell id="c0" edge="1" parent="1" source="start" style="strokeWidth=2;" target="f1">
