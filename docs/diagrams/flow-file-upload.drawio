<mxfile host="app.diagrams.net">
  <diagram name="文件上传流程" id="flow-file-upload">
    <mxGraphModel dx="1076" dy="594" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="start" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;fontColor=#fff;fontSize=12;" value="开始" vertex="1">
          <mxGeometry x="560" y="30" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="管理员选择文件上传" vertex="1">
          <mxGeometry x="510" y="100" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d1" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="文件类型检查&lt;br&gt;(jpg/png/mp4/pdf/doc)" vertex="1">
          <mxGeometry x="510" y="170" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err1" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="提示文件格式错误" vertex="1">
          <mxGeometry x="770" y="190" width="120" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d2" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="文件大小检查&lt;br&gt;(图片5MB/视频50MB/文档20MB)" vertex="1">
          <mxGeometry x="490" y="300" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="err2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="提示文件过大" vertex="1">
          <mxGeometry x="790" y="320" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f2" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="POST /api/admin/upload&lt;br&gt;(multipart/form-data)" vertex="1">
          <mxGeometry x="500" y="430" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d3" parent="1" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="后端MIME类型&lt;br&gt;二次验证" vertex="1">
          <mxGeometry x="520" y="520" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="err3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" value="返回400错误" vertex="1">
          <mxGeometry x="760" y="535" width="110" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="生成唯一文件名(UUID)" vertex="1">
          <mxGeometry x="510" y="640" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="保存到uploadDir目录" vertex="1">
          <mxGeometry x="510" y="710" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="RabbitMQ异步处理&lt;br&gt;(生成缩略图/压缩)" vertex="1">
          <mxGeometry x="500" y="780" width="200" height="50" as="geometry" />
        </mxCell>
        <mxCell id="f6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" value="返回文件访问URL" vertex="1">
          <mxGeometry x="510" y="860" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="f7" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="前端更新表单字段" vertex="1">
          <mxGeometry x="510" y="930" width="180" height="40" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#6c8ebf;fontColor=#fff;fontSize=12;" value="完成" vertex="1">
