# ===========================================
# 侗乡医药数字展示平台 - Docker环境变量配置
# ===========================================
# 复制此文件为 .env 并修改相应配置

# ============ MySQL配置 ============
MYSQL_ROOT_PASSWORD=root123456
MYSQL_USER=dongmedicine
MYSQL_PASSWORD=dongmedicine123
MYSQL_PORT=3306

# ============ Redis配置 ============
REDIS_PASSWORD=redis123456
REDIS_PORT=6379

# ============ JWT配置 ============
# 生产环境请使用至少64字符的强密钥
JWT_SECRET=your-super-secret-jwt-key-must-be-at-least-64-characters-long-for-hs512-algorithm-security
JWT_EXPIRATION=86400000

# ============ 后端配置 ============
BACKEND_PORT=8080

# ============ 前端配置 ============
FRONTEND_PORT=80

# ============ CORS配置 ============
# 前端访问地址，多个用逗号分隔
CORS_ALLOWED_ORIGIN=http://localhost

# ============ AI配置（可选） ============
DEEPSEEK_API_KEY=

# ============ kkFileView配置 ============
KKFILEVIEW_PORT=8012
