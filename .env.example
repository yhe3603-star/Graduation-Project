# ===========================================
# 侗乡医药数字展示平台 - Docker 环境变量配置
# ===========================================
# 复制此文件为 .env 并修改相应配置

# ============ MySQL 配置 ============
MYSQL_ROOT_PASSWORD=
MYSQL_PORT=3306

# ============ Redis 配置 ============
REDIS_PASSWORD=
REDIS_PORT=6379

# ============ RabbitMQ 配置 ============
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=

# ============ JWT 配置 ============
JWT_SECRET=
JWT_EXPIRATION=86400000

# ============ 后端配置 ============
BACKEND_PORT=8080
BACKEND_IMAGE=ghcr.io/yhe3603-star/dong-medicine-backend:latest

# ============ 前端配置 ============
FRONTEND_PORT=80
FRONTEND_IMAGE=ghcr.io/yhe3603-star/dong-medicine-frontend:latest

# ============ CORS 配置 ============
CORS_ALLOWED_ORIGIN=http://localhost:3000

# ============ RabbitMQ 开关 ============
# 设为 false 可在低内存服务器上禁用 RabbitMQ
APP_RABBITMQ_ENABLED=true

# ============ JVM 配置 ============
# 低内存服务器(1.6GB): -Xms256m -Xmx384m -XX:+UseSerialGC
# 4GB+ 服务器: -Xms512m -Xmx768m -XX:+UseG1GC
JAVA_OPTS=-Xms256m -Xmx384m -XX:+UseSerialGC -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/app/logs/heapdump.hprof -Djava.security.egd=file:/dev/./urandom

# ============ AI 配置（可选） ============
DEEPSEEK_API_KEY=

# ============ KKFileView 配置 ============
KKFILEVIEW_URL=http://kkfileview:8012

# ============ WebSocket 配置 ============
WS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
